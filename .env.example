# [DO - Kouria Tasko] L'équipe utilise un cluster MongoDB Atlas (M0 gratuit)
# partagé entre les deux membres pour garantir un environnement identique.
# Copier ce fichier en .env (jamais committé) et y coller la vraie MONGODB_URI.

# === Configuration TerrangaFood ===

# MongoDB — URI de connexion
# Option 1 : MongoDB local
# MONGODB_URI=mongodb://localhost:27017/terrangafood
# Option 2 : MongoDB Atlas (remplacez par vos identifiants)
MONGODB_URI=mongodb+srv://UTILISATEUR:MOT_DE_PASSE@cluster0.xxxxx.mongodb.net/terrangafood

# Port de l'API Express
PORT=3001

# URL de l'API (utilisée par le frontend)
NEXT_PUBLIC_API_URL=http://localhost:3001/api
